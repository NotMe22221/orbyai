# ──────────────────────────────────────────────────────────────────
# Resident Secretary — Environment Variables
# Copy this to .env.local and fill in real values
# ⚠️  NEVER commit .env.local to git
# ──────────────────────────────────────────────────────────────────

# Deploy AI (LLM calls for Agent A + B)
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
AUTH_URL=https://api-auth.deploy.ai/oauth2/token
API_URL=https://core-api.deploy.ai
ORG_ID=your_org_id

# ElevenLabs (STT + TTS + Conversational Agent)
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id

# Supabase (session + audit logging)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# App
# Local dev:
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
# Vercel production (update after first deploy):
# NEXT_PUBLIC_BACKEND_URL=https://your-project.vercel.app

# Set to false when real API keys are available
USE_MOCKS=true

# Vercel automatically injects these — do not set manually:
# VERCEL_URL, VERCEL_ENV, VERCEL_REGION
